function advancedBase64Encode(str) {
    const standard = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/';
    const custom = generateSecureRandom(64);
    let result = Buffer.from(str).toString('base64');
